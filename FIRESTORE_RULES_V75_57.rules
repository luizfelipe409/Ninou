rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAdmin() {
      return isSignedIn()
        && userEmail() == "luizfelipe.dasilva@gmail.com";
    }

    function isFamilyAccount() {
      return isSignedIn()
        && userEmail() == "francisco@gmail.com";
    }

    function mainFamilyId() {
      return "ninou-family-luizfelipe";
    }

    function isMainFamily(familyId) {
      return familyId == mainFamilyId();
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasNinouAccess(familyId) {
      return isSignedIn()
        && isMainFamily(familyId)
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/access/ninou)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/access/ninou).data.familyId == familyId;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && isMainFamily(familyId)
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function canReadFamily(familyId) {
      return isAdmin() || isFamilyAccount() || isFamilyMember(familyId) || hasNinouAccess(familyId);
    }

    function canWriteFamily(familyId) {
      return isAdmin() || isFamilyAccount() || isFamilyMember(familyId) || hasNinouAccess(familyId);
    }

    match /families/{familyId} {
      allow read: if canReadFamily(familyId);
      allow create, update: if isAdmin() || isFamilyAccount();
      allow delete: if isAdmin();

      match /profile/{docId} {
        allow read: if canReadFamily(familyId);
        allow create, update: if canWriteFamily(familyId)
          && docId == "main";
        allow delete: if isAdmin();
      }

      match /days/{dayId} {
        allow read: if canReadFamily(familyId);
        allow create, update: if canWriteFamily(familyId)
          && dayId.matches('^\\d{4}-\\d{2}-\\d{2}$');
        allow delete: if isAdmin();
      }

      match /members/{memberId} {
        allow read: if canReadFamily(familyId);
        allow create, update: if isAdmin()
          || isFamilyAccount()
          || isSelf(memberId);
        allow delete: if isAdmin() || isFamilyAccount();
      }

      match /invitations/{inviteCode} {
        allow read: if canReadFamily(familyId);
        allow create, update: if canWriteFamily(familyId);
        allow delete: if isAdmin() || isFamilyAccount();
      }
    }

    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create, update: if isAdmin() || isSelf(userId);
      allow delete: if isAdmin();

      match /access/{accessId} {
        allow read: if isAdmin() || isSelf(userId);
        allow create, update: if isAdmin() || isSelf(userId) || isFamilyAccount();
        allow delete: if isAdmin() || isSelf(userId);
      }
    }
  }
}
