rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isGlobalAdmin() {
      return isSignedIn()
        && userEmail() == "luizfelipe.dasilva@gmail.com";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function memberPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid);
    }

    function userFamilyPath(familyId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/families/$(familyId);
    }

    function isFamilyMember(familyId) {
      return isSignedIn() && exists(memberPath(familyId));
    }

    function hasUserFamilyLink(familyId) {
      return isSignedIn() && exists(userFamilyPath(familyId));
    }

    function memberRole(familyId) {
      return isFamilyMember(familyId)
        ? get(memberPath(familyId)).data.role
        : "";
    }

    function userFamilyRole(familyId) {
      return hasUserFamilyLink(familyId)
        ? get(userFamilyPath(familyId)).data.role
        : "";
    }

    function roleCanManage(role) {
      return role in ["admin", "owner", "responsavel", "pai", "mae"];
    }

    function roleCanWriteRoutine(role) {
      return role in ["admin", "owner", "responsavel", "pai", "mae", "cuidador"];
    }

    function isFamilyAdmin(familyId) {
      return isGlobalAdmin()
        || (isSignedIn() && roleCanManage(memberRole(familyId)))
        || (isSignedIn() && !isFamilyMember(familyId) && roleCanManage(userFamilyRole(familyId)));
    }

    function canUseFamily(familyId) {
      return isGlobalAdmin() || isFamilyMember(familyId) || hasUserFamilyLink(familyId);
    }

    function canWriteFamilyRoutine(familyId) {
      return isGlobalAdmin()
        || (isSignedIn() && roleCanWriteRoutine(memberRole(familyId)))
        || (isSignedIn() && !isFamilyMember(familyId) && roleCanWriteRoutine(userFamilyRole(familyId)));
    }

    match /families/{familyId} {
      allow read: if canUseFamily(familyId);
      allow create: if isGlobalAdmin() || isSignedIn();
      allow update: if isGlobalAdmin()
        || isFamilyAdmin(familyId)
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow delete: if isGlobalAdmin();

      match /profile/{profileId} {
        allow read: if canUseFamily(familyId);
        allow create, update: if isFamilyAdmin(familyId);
        allow delete: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /days/{dayId} {
        allow read: if canUseFamily(familyId);
        allow create, update: if canWriteFamilyRoutine(familyId);
        allow delete: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /members/{memberId} {
        allow read: if canUseFamily(familyId);
        allow create: if isGlobalAdmin() || isSelf(memberId) || isFamilyAdmin(familyId);
        allow update: if isGlobalAdmin() || isSelf(memberId) || isFamilyAdmin(familyId);
        allow delete: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /invites/{inviteId} {
        allow read: if isGlobalAdmin() || isFamilyAdmin(familyId);
        allow create, update, delete: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /invitations/{inviteId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /migrations/{migrationId} {
        allow read, write: if isGlobalAdmin() || isFamilyAdmin(familyId);
      }

      match /{document=**} {
        allow read, write: if isGlobalAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId) || isGlobalAdmin();

      match /families/{familyId} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }

      match /access/{docId} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }

      match /account/{docId} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }

      match /days/{dayId} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }

      match /profile/{docId} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }

      match /{document=**} {
        allow read, write: if isSelf(userId) || isGlobalAdmin();
      }
    }

    match /invites/{inviteId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isGlobalAdmin();
    }

    // Migração/diagnóstico legado: permitido apenas ao admin global.
    match /{document=**} {
      allow read, write: if isGlobalAdmin();
    }
  }
}
