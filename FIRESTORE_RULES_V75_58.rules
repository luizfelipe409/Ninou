rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /*
      Ninou v75.58 — Regras multi-família

      Objetivo:
      - Cada família fica isolada por familyId.
      - Usuários só acessam famílias em que são membros, donos ou convidados.
      - Permite criação de nova família pelo próprio usuário autenticado.
      - Mantém compatibilidade com a família atual do Francisco e com access/ninou legado.
      - Convites novos usam families/{familyId}/invitations/{inviteCode}; o espelho global /invites/{code}
        existe apenas para localizar familyId por código secreto.
    */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAdmin() {
      return isSignedIn()
        && userEmail() == "luizfelipe.dasilva@gmail.com";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFranciscoFamily(familyId) {
      return familyId == "ninou-family-luizfelipe";
    }

    function isFranciscoFamilyAccountFor(familyId) {
      return isSignedIn()
        && isFranciscoFamily(familyId)
        && userEmail() == "francisco@gmail.com";
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function memberPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid);
    }

    function userFamilyAccessPath(userId, familyId) {
      return /databases/$(database)/documents/users/$(userId)/families/$(familyId);
    }

    function legacyAccessPath(userId) {
      return /databases/$(database)/documents/users/$(userId)/access/ninou;
    }

    function invitationPath(familyId, inviteCode) {
      return /databases/$(database)/documents/families/$(familyId)/invitations/$(inviteCode);
    }

    function isFamilyOwnerByDoc(familyId) {
      return isSignedIn()
        && exists(familyPath(familyId))
        && get(familyPath(familyId)).data.ownerUid == request.auth.uid;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && exists(memberPath(familyId));
    }

    function hasUserFamilyAccess(familyId) {
      return isSignedIn()
        && exists(userFamilyAccessPath(request.auth.uid, familyId))
        && get(userFamilyAccessPath(request.auth.uid, familyId)).data.familyId == familyId;
    }

    function hasLegacyAccess(familyId) {
      return isSignedIn()
        && exists(legacyAccessPath(request.auth.uid))
        && get(legacyAccessPath(request.auth.uid)).data.familyId == familyId;
    }

    function memberRoleIs(familyId, roles) {
      return isFamilyMember(familyId)
        && get(memberPath(familyId)).data.role in roles;
    }

    function userFamilyRoleIs(familyId, roles) {
      return hasUserFamilyAccess(familyId)
        && get(userFamilyAccessPath(request.auth.uid, familyId)).data.role in roles;
    }

    function legacyRoleIs(familyId, roles) {
      return hasLegacyAccess(familyId)
        && get(legacyAccessPath(request.auth.uid)).data.role in roles;
    }

    function canReadFamily(familyId) {
      return isAdmin()
        || isFranciscoFamilyAccountFor(familyId)
        || isFamilyOwnerByDoc(familyId)
        || isFamilyMember(familyId)
        || hasUserFamilyAccess(familyId)
        || hasLegacyAccess(familyId);
    }

    function canManageFamily(familyId) {
      return isAdmin()
        || isFranciscoFamilyAccountFor(familyId)
        || isFamilyOwnerByDoc(familyId)
        || memberRoleIs(familyId, ["owner", "responsavel", "responsável"])
        || userFamilyRoleIs(familyId, ["owner", "responsavel", "responsável"])
        || legacyRoleIs(familyId, ["owner", "responsavel", "responsável"]);
    }

    function canWriteRoutine(familyId) {
      return canManageFamily(familyId)
        || memberRoleIs(familyId, ["caregiver", "cuidador"])
        || userFamilyRoleIs(familyId, ["caregiver", "cuidador"])
        || legacyRoleIs(familyId, ["caregiver", "cuidador"]);
    }

    function inviteExists(familyId, inviteCode) {
      return exists(invitationPath(familyId, inviteCode));
    }

    function inviteData(familyId, inviteCode) {
      return get(invitationPath(familyId, inviteCode)).data;
    }

    function activeInviteAllowsJoin(familyId, inviteCode) {
      return isSignedIn()
        && inviteCode is string
        && inviteCode.size() > 0
        && inviteExists(familyId, inviteCode)
        && inviteData(familyId, inviteCode).familyId == familyId
        && inviteData(familyId, inviteCode).status == "active";
    }

    function accessInviteCode() {
      return request.resource.data.keys().hasAny(["inviteCode"])
        ? request.resource.data.inviteCode
        : (
          request.resource.data.keys().hasAny(["joinedByInvite"])
            ? request.resource.data.joinedByInvite
            : ""
        );
    }

    function validRole(role) {
      return role in ["owner", "caregiver", "cuidador", "responsavel", "responsável"];
    }

    function hasForbiddenPhotoFields() {
      return request.resource.data.keys().hasAny([
        "photo",
        "foto",
        "photoURL",
        "photoUrl",
        "babyPhoto",
        "babyPhotoUrl",
        "babyPhotoBase64",
        "avatarBase64",
        "imageBase64",
        "profilePhoto",
        "profilePhotoUrl",
        "profileImage",
        "profileImageBase64"
      ]);
    }

    function forbiddenPhotoFieldsAreEmpty() {
      return
        (!request.resource.data.keys().hasAny(["photo"]) || request.resource.data.photo == "" || request.resource.data.photo == null)
        && (!request.resource.data.keys().hasAny(["foto"]) || request.resource.data.foto == "" || request.resource.data.foto == null)
        && (!request.resource.data.keys().hasAny(["photoURL"]) || request.resource.data.photoURL == "" || request.resource.data.photoURL == null)
        && (!request.resource.data.keys().hasAny(["photoUrl"]) || request.resource.data.photoUrl == "" || request.resource.data.photoUrl == null)
        && (!request.resource.data.keys().hasAny(["babyPhoto"]) || request.resource.data.babyPhoto == "" || request.resource.data.babyPhoto == null)
        && (!request.resource.data.keys().hasAny(["babyPhotoUrl"]) || request.resource.data.babyPhotoUrl == "" || request.resource.data.babyPhotoUrl == null)
        && (!request.resource.data.keys().hasAny(["babyPhotoBase64"]) || request.resource.data.babyPhotoBase64 == "" || request.resource.data.babyPhotoBase64 == null)
        && (!request.resource.data.keys().hasAny(["avatarBase64"]) || request.resource.data.avatarBase64 == "" || request.resource.data.avatarBase64 == null)
        && (!request.resource.data.keys().hasAny(["imageBase64"]) || request.resource.data.imageBase64 == "" || request.resource.data.imageBase64 == null)
        && (!request.resource.data.keys().hasAny(["profilePhoto"]) || request.resource.data.profilePhoto == "" || request.resource.data.profilePhoto == null)
        && (!request.resource.data.keys().hasAny(["profilePhotoUrl"]) || request.resource.data.profilePhotoUrl == "" || request.resource.data.profilePhotoUrl == null)
        && (!request.resource.data.keys().hasAny(["profileImage"]) || request.resource.data.profileImage == "" || request.resource.data.profileImage == null)
        && (!request.resource.data.keys().hasAny(["profileImageBase64"]) || request.resource.data.profileImageBase64 == "" || request.resource.data.profileImageBase64 == null);
    }

    function isAvatarOnlyPayload() {
      return !hasForbiddenPhotoFields()
        || forbiddenPhotoFieldsAreEmpty();
    }

    match /families/{familyId} {
      allow read: if canReadFamily(familyId);

      allow create: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.familyId == familyId
          && request.resource.data.status == "active"
        );

      allow update: if canManageFamily(familyId);
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow read: if canReadFamily(familyId);

        allow create, update: if canManageFamily(familyId)
          && profileId == "main"
          && isAvatarOnlyPayload();

        allow delete: if isAdmin();
      }

      match /days/{dayId} {
        allow read: if canReadFamily(familyId);

        allow create, update: if canWriteRoutine(familyId)
          && dayId.matches('^\\d{4}-\\d{2}-\\d{2}$');

        allow delete: if canManageFamily(familyId);
      }

      match /members/{userId} {
        allow read: if canReadFamily(familyId);

        allow create: if isAdmin()
          || canManageFamily(familyId)
          || (
            isSelf(userId)
            && isFamilyOwnerByDoc(familyId)
            && request.resource.data.role in ["owner", "responsavel", "responsável"]
          )
          || (
            isSelf(userId)
            && request.resource.data.role is string
            && validRole(request.resource.data.role)
            && (
              isFranciscoFamilyAccountFor(familyId)
              || (
                request.resource.data.inviteCode is string
                && activeInviteAllowsJoin(familyId, request.resource.data.inviteCode)
              )
              || (
                request.resource.data.joinedByInvite is string
                && activeInviteAllowsJoin(familyId, request.resource.data.joinedByInvite)
              )
            )
          );

        allow update: if isAdmin()
          || canManageFamily(familyId)
          || (
            isSelf(userId)
            && request.resource.data.role == resource.data.role
          );

        allow delete: if isAdmin() || canManageFamily(familyId);
      }

      match /invitations/{inviteCode} {
        allow get: if canReadFamily(familyId)
          || (
            isSignedIn()
            && resource.data.familyId == familyId
            && resource.data.status == "active"
          );

        allow list: if canReadFamily(familyId);

        allow create: if canManageFamily(familyId)
          && request.resource.data.familyId == familyId
          && request.resource.data.status == "active";

        allow update: if canManageFamily(familyId)
          && request.resource.data.familyId == familyId;

        allow delete: if canManageFamily(familyId);
      }

      match /invites/{inviteCode} {
        allow get: if canReadFamily(familyId)
          || (
            isSignedIn()
            && resource.data.familyId == familyId
            && resource.data.status in ["active", "pending", "accepted"]
          );

        allow list: if canReadFamily(familyId);
        allow create, update, delete: if canManageFamily(familyId);
      }

      match /migrations/{migrationId} {
        allow read, create, update, delete: if isAdmin();

        match /logs/{logId} {
          allow read, create, update, delete: if isAdmin();
        }
      }

      match /{document=**} {
        allow read: if canReadFamily(familyId);
        allow write: if isAdmin();
      }
    }

    match /invites/{inviteCode} {
      allow get: if isAdmin()
        || (
          isSignedIn()
          && resource.data.status == "active"
        )
        || (
          isSignedIn()
          && resource.data.email == userEmail()
        );

      allow list: if isAdmin();

      allow create: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.familyId is string
          && canManageFamily(request.resource.data.familyId)
        );

      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.familyId is string
          && canManageFamily(resource.data.familyId)
        );

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();

      allow create, update: if (isSelf(userId) || isAdmin())
        && isAvatarOnlyPayload();

      allow delete: if isAdmin();

      match /families/{familyId} {
        allow read: if isSelf(userId) || isAdmin();

        allow create, update: if isAdmin()
          || (
            isSelf(userId)
            && request.resource.data.familyId == familyId
            && request.resource.data.role is string
            && validRole(request.resource.data.role)
            && (
              canReadFamily(familyId)
              || isFamilyOwnerByDoc(familyId)
              || activeInviteAllowsJoin(familyId, accessInviteCode())
            )
          );

        allow delete: if isSelf(userId) || isAdmin();
      }

      match /access/{accessId} {
        allow read: if isSelf(userId) || isAdmin();

        allow create, update: if isAdmin()
          || (
            isSelf(userId)
            && request.resource.data.familyId is string
            && request.resource.data.role is string
            && validRole(request.resource.data.role)
            && (
              canReadFamily(request.resource.data.familyId)
              || isFamilyOwnerByDoc(request.resource.data.familyId)
              || activeInviteAllowsJoin(
                request.resource.data.familyId,
                accessInviteCode()
              )
            )
          );

        allow delete: if isSelf(userId) || isAdmin();
      }

      match /profile/{profileId} {
        allow read: if isSelf(userId) || isAdmin();

        allow create, update: if (isSelf(userId) || isAdmin())
          && isAvatarOnlyPayload();

        allow delete: if isAdmin();
      }

      match /account/{profileId} {
        allow read: if isSelf(userId) || isAdmin();

        allow create, update: if (isSelf(userId) || isAdmin())
          && isAvatarOnlyPayload();

        allow delete: if isSelf(userId) || isAdmin();
      }

      match /days/{dayId} {
        allow read: if isSelf(userId) || isAdmin();
        allow create, update: if isSelf(userId) || isAdmin();
        allow delete: if isSelf(userId) || isAdmin();
      }

      match /activities/{activityId} {
        allow read: if isSelf(userId) || isAdmin();
        allow create, update: if isSelf(userId) || isAdmin();
        allow delete: if isSelf(userId) || isAdmin();
      }

      match /weights/{weightId} {
        allow read: if isSelf(userId) || isAdmin();
        allow create, update: if isSelf(userId) || isAdmin();
        allow delete: if isSelf(userId) || isAdmin();
      }

      match /pesos/{weightId} {
        allow read: if isSelf(userId) || isAdmin();
        allow create, update: if isSelf(userId) || isAdmin();
        allow delete: if isSelf(userId) || isAdmin();
      }
    }

    match /{path=**}/activities/{activityId} {
      allow read: if isAdmin();
    }

    match /{path=**}/days/{dayId} {
      allow read: if isAdmin();
    }

    match /{path=**}/profile/{profileId} {
      allow read: if isAdmin();
    }

    match /{path=**}/access/{accessId} {
      allow read: if isAdmin();
    }

    match /{path=**}/families/{familyId} {
      allow read: if isAdmin();
    }

    match /{path=**}/account/{profileId} {
      allow read: if isAdmin();
    }

    match /{path=**}/weights/{weightId} {
      allow read: if isAdmin();
    }

    match /{path=**}/pesos/{weightId} {
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
