{
  "expo": {
    "name": "Ninou",
    "slug": "ninou",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ninou-icon.png",
    "scheme": "ninou",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ninou-icon.png",
      "bundleIdentifier": "com.ninou.app",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "android": {
      "package": "com.ninou.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1D1435",
        "foregroundImage": "./assets/images/ninou-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ninou-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#120B24",
          "image": "./assets/images/ninou-splash.png",
          "imageWidth": 160
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-sharing",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b35fd43-9837-4120-aed0-d9c9a29d080c"
      }
    }
  }
}
